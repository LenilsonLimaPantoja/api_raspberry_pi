[Unit]
# Descrição do serviço para facilitar identificação
Description=Gerenciador de Wi-Fi: Cliente ou Access Point

# Esse serviço será iniciado após a rede básica estar disponível
After=network.target network-online.target

# Garante que o serviço espere a rede estar online
Wants=network-online.target

[Service]
# Tipo "oneshot" indica que é um script que roda e termina (não é contínuo)
Type=oneshot

# Caminho completo do script que será executado
ExecStart=/home/pi/Desktop/api_raspberry_pi/src/scripts/wifi_manager.sh

# Mantém o serviço "ativo" no systemd após o script finalizar
RemainAfterExit=true

[Install]
# Inicia esse serviço no boot em modo multiusuário (modo padrão do Raspberry)
WantedBy=multi-user.target


