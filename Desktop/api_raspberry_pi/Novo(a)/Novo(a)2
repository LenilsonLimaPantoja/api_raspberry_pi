pi@raspberrypi:~ $ sudo cat /etc/hostapd/hostapd.conf 
interface=wlan0                # Interface Wi-Fi usada
driver=nl80211                # Driver do hostapd para interface wlan0
ssid=Balanca-AP               # Nome da rede Wi-Fi do ponto de acesso
hw_mode=g                    # Modo wireless 802.11g
channel=7                    # Canal Wi-Fi
wmm_enabled=0                # Desabilita WMM (Wi-Fi Multimedia)
macaddr_acl=0                # Sem controle de MAC
auth_algs=1                  # Algoritmo de autenticação
ignore_broadcast_ssid=0      # SSID visível para clientes
wpa=2                        # WPA2 habilitado
wpa_passphrase=12345678      # Senha da rede Wi-Fi do AP
wpa_key_mgmt=WPA-PSK         # Gerenciamento de chave WPA-PSK
rsn_pairwise=CCMP            # Tipo de criptografia
